# Agent container — pure execution sandbox for tool calls.
# One pod per user. PVC mounted at /home/node (user's home directory).
# The pod runs `sleep infinity` — the server drives all tool execution via k8s exec.

FROM node:22-alpine

RUN apk add --no-cache python3

# Set up home directory (will be overlaid by PVC in k8s)
RUN mkdir -p /home/node && chown -R node:node /home/node

USER node
WORKDIR /home/node

CMD ["sleep", "infinity"]
