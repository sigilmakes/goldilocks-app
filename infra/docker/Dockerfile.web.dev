# Dev-mode web app: tsx watch (Gateway/Express) + vite dev server (React)
# Used by Tilt with live_update for sub-second file syncs.
# IMPORTANT: agent-service runs in its own deployment; do not start it here.

FROM node:22-alpine

WORKDIR /app

# Install deps (including devDependencies)
COPY package.json package-lock.json ./
COPY server/package.json ./server/
COPY frontend/package.json ./frontend/
RUN npm install

# Copy source (overridden by Tilt live_update on changes)
COPY . .

# Gateway (3000) + Vite (5173)
EXPOSE 3000 5173

# Run only gateway + frontend here.
# --host 0.0.0.0 on Vite is critical — without it, Vite only binds
# localhost inside the container and is unreachable from outside.
CMD ["npm", "run", "dev:web"]
