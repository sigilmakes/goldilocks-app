# Agent container — runs pi in RPC mode via k8s exec.
# One pod per user. PVC mounted at /home/node (user's home directory).
# The pod runs `sleep infinity` — pi is started via k8s exec.

FROM node:22-alpine

# Install Pi SDK
WORKDIR /opt/pi
RUN echo '{"type":"module","dependencies":{"@mariozechner/pi-coding-agent":"*"}}' > package.json \
    && npm install --omit=dev \
    && ln -s /opt/pi/node_modules/.bin/pi /usr/local/bin/pi

# Verify pi is installed
RUN pi --version

# Set up home directory (will be overlaid by PVC in k8s)
RUN mkdir -p /home/node && chown -R node:node /home/node

USER node
WORKDIR /home/node

CMD ["sleep", "infinity"]
