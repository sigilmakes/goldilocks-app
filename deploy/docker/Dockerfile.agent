# Agent container — paper-thin: just Pi SDK + MCP client
# All science tools and HPC access go through the MCP server.
# No SSH keys, no Python, no science deps in this image.

FROM node:22-alpine AS base

# Create non-root user
RUN addgroup -g 1000 agent && adduser -u 1000 -G agent -s /bin/sh -D agent

# Install pi SDK globally
RUN npm install -g @mariozechner/pi-coding-agent

# Create workspace directories
RUN mkdir -p /work /tmp/pi-session && chown -R agent:agent /work /tmp/pi-session

# Copy the goldilocks skill doc
COPY skills/ /home/agent/skills/
COPY AGENTS.md /home/agent/AGENTS.md
RUN chown -R agent:agent /home/agent

USER agent
WORKDIR /work

# The agent process is started by the web app when proxying a session.
# It runs Pi SDK, connects to the MCP server for tools, and exposes
# a WebSocket endpoint for the web app to proxy user messages.
#
# Environment variables set by the web app at pod creation:
#   USER_ID, SESSION_ID, WEB_APP_URL, MCP_SERVER_URL
#
# The entrypoint script initializes the Pi session and starts listening.
COPY --chown=agent:agent deploy/docker/agent-entrypoint.sh /home/agent/entrypoint.sh
RUN chmod +x /home/agent/entrypoint.sh

EXPOSE 8080

ENTRYPOINT ["/home/agent/entrypoint.sh"]
