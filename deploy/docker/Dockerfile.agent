# Agent container — paper-thin: just Pi SDK + MCP client
# All science tools and HPC access go through the MCP server.
# No SSH keys, no Python, no science deps in this image.

FROM node:22-alpine AS base

# node:22-alpine already has user 'node' (uid 1000, gid 1000)
# Use that as our non-root agent user

# Install pi SDK globally
RUN npm install -g @mariozechner/pi-coding-agent

# Create workspace directories owned by node user
RUN mkdir -p /work /tmp/pi-session && chown -R node:node /work /tmp/pi-session

# Copy the goldilocks skill doc
COPY skills/ /home/node/skills/
COPY AGENTS.md /home/node/AGENTS.md
RUN chown -R node:node /home/node

USER node
WORKDIR /work

# The agent process is started by the web app when proxying a session.
# It runs Pi SDK, connects to the MCP server for tools, and exposes
# a WebSocket endpoint for the web app to proxy user messages.
#
# Environment variables set by the web app at pod creation:
#   USER_ID, SESSION_ID, WEB_APP_URL, MCP_SERVER_URL
COPY --chown=node:node deploy/docker/agent-entrypoint.sh /home/node/entrypoint.sh
RUN chmod +x /home/node/entrypoint.sh

EXPOSE 8080

ENTRYPOINT ["/home/node/entrypoint.sh"]
