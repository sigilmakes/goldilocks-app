# Agent container — runs Pi SDK in RPC mode (JSON-RPC over stdin/stdout).
# The web app communicates via k8s exec API. No custom entrypoint needed.

FROM node:22-alpine AS base

# Install Pi SDK as a local package (ESM-only, global install has module resolution issues)
WORKDIR /home/node/agent
RUN echo '{"type":"module","dependencies":{"@mariozechner/pi-coding-agent":"*"}}' > package.json \
    && npm install --omit=dev \
    && ln -s /home/node/agent/node_modules/.bin/pi /usr/local/bin/pi

# Create workspace directories owned by node user
RUN mkdir -p /work /tmp/pi-session && chown -R node:node /work /tmp/pi-session /home/node

# Copy the goldilocks skill doc
COPY skills/ /home/node/skills/
COPY AGENTS.md /home/node/AGENTS.md

USER node
WORKDIR /work

# The pod spec overrides the command to "sleep infinity" so the container
# stays alive for k8s exec. This CMD is the default for standalone use.
CMD ["pi", "--mode", "rpc"]
