# Web app container — Express server + React frontend
# Handles auth, UI, pod orchestration, WebSocket proxy to agent containers

# Stage 1: Build frontend
FROM node:22-alpine AS frontend-build
WORKDIR /build
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# Stage 2: Build server
FROM node:22-alpine AS server-build
WORKDIR /build
COPY server/package.json server/package-lock.json ./
RUN npm ci
COPY server/ ./
RUN npm run build

# Stage 3: Production image
FROM node:22-alpine

RUN addgroup -g 1000 app && adduser -u 1000 -G app -s /bin/sh -D app

WORKDIR /app

# Server dependencies (production only)
COPY server/package.json server/package-lock.json ./server/
RUN cd server && npm ci --omit=dev

# Built server
COPY --from=server-build /build/dist ./server/dist/

# Built frontend
COPY --from=frontend-build /build/dist ./frontend/dist/

# Skills and agent context (for LocalSessionBackend mode)
COPY skills/ ./skills/
COPY AGENTS.md ./AGENTS.md
COPY bin/ ./bin/

# Goldilocks CLI needs to be executable
RUN chmod +x bin/goldilocks

# Data directories
RUN mkdir -p /data/workspaces && chown -R app:app /data

USER app

ENV NODE_ENV=production
ENV DATA_DIR=/data
ENV WORKSPACE_ROOT=/data/workspaces
ENV PORT=3000

EXPOSE 3000

CMD ["node", "server/dist/index.js"]
