# Server
PORT=3000
NODE_ENV=development

# Database
DATA_DIR=./data

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
ENCRYPTION_KEY=change-me-32-bytes-for-aes-256

# API Keys (optional - users can provide their own)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Session management
MAX_SESSIONS=20
SESSION_IDLE_TIMEOUT_MS=300000
